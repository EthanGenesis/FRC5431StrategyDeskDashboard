# Required for live TBA-backed routes
TBA_AUTH_KEY=replace-with-your-tba-auth-key
TBA_WEBHOOK_SECRET=

# Optional FIRST official API integration
FIRST_API_BASE_URL=https://frc-api.firstinspires.org/v3.0
FIRST_API_USERNAME=
FIRST_API_AUTH_TOKEN=

# Optional Nexus event-ops integration
NEXUS_API_BASE_URL=https://frc.nexus/api/v1
NEXUS_API_KEY=

# Optional runtime logging / telemetry
APP_LOG_LEVEL=info
OTEL_ENABLED=false
OTEL_DIAG_LOGGING=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=tbsb-dashboard

# Supabase public client
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-your-supabase-publishable-key

# Supabase server-only admin client
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-supabase-service-role-key

# Optional hot data plane proxy / shadow-compare
HOT_DATA_PLANE_URL=
HOT_DATA_PLANE_BEARER_TOKEN=
HOT_DATA_PLANE_MODE=off
HOT_DATA_PLANE_PROXY_ROUTES=bootstrap,active-target,team-events,refresh-active-target,compare-bundle,predict-bundle,alliance-bundle,playoff-bundle,impact-bundle,pick-list-bundle

# Optional hot cache (Upstash Redis REST API)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
HOT_CACHE_FRESH_SECONDS=15
HOT_CACHE_STALE_SECONDS=60
